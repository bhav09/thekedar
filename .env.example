# Thekedar — Environment Configuration Template
# Copy this file to .env and configure the variables.

# --- Core ---
THEKEDAR_ENVIRONMENT=local
THEKEDAR_DEMO_MODE=true
THEKEDAR_LOG_LEVEL=INFO

# --- Data Stores ---
THEKEDAR_REDIS_URL=redis://localhost:6379/0
THEKEDAR_DATABASE_URL=postgresql+psycopg://thekedar:thekedar@localhost:5432/thekedar

# --- Security & Webhooks ---
# THEKEDAR_JWT_SECRET=your_jwt_secret_key_here
THEKEDAR_REQUIRE_WEBHOOK_SIGNATURE=false
THEKEDAR_WEBHOOK_RATE_LIMIT_RPS=100
THEKEDAR_MAX_REQUEST_BODY_BYTES=262144
THEKEDAR_DEFAULT_TENANT_ID=default

# --- Service URLs ---
THEKEDAR_DASHBOARD_URL=http://localhost:8081
THEKEDAR_WEBHOOK_INGRESS_URL=http://localhost:8080
THEKEDAR_WORKSPACE_CONFIG_PATH=config/workspace.yaml

# --- MCP Gateway & Integrations ---
# GitHub Personal Access Token (PAT) can be generated at: https://github.com/settings/tokens
THEKEDAR_BIFROST_URL=http://localhost:8090
GITHUB_TOKEN=your_github_personal_access_token_here
# GitHub Webhook Secret is a custom string you set when registering webhooks on your repo settings.
# Docs: https://docs.github.com/en/webhooks/using-webhooks/securing-your-webhooks
# GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# --- Jira Cloud Settings ---
# Create an Atlassian API Token at: https://id.atlassian.com/manage-profile/security/api-tokens
# Docs: https://developer.atlassian.com/cloud/jira/platform/basic-auth-for-rest-apis/
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token_here

# --- GCP Settings (Workstations) ---
# Create and view projects in Google Cloud Console: https://console.cloud.google.com/
GCP_PROJECT_ID=your-gcp-project-id-here
GCP_REGION=us-central1

# --- Agent Context & Execution ---
THEKEDAR_LOCAL_IDE=1
# THEKEDAR_LOCAL_REPO_PATH=
THEKEDAR_IDE_ADAPTER=auto
THEKEDAR_LLM_PROVIDER=mock
THEKEDAR_CONTEXT_REINDEX_HOURS=24
THEKEDAR_APPROVAL_TTL_HOURS=72
THEKEDAR_MAX_CODING_ITERATIONS=25

# --- M7 context + IDE execution ---
THEKEDAR_LOCAL_IDE=1
# THEKEDAR_LOCAL_REPO_PATH=
THEKEDAR_IDE_ADAPTER=auto
THEKEDAR_LLM_PROVIDER=mock
THEKEDAR_CONTEXT_REINDEX_HOURS=24
THEKEDAR_APPROVAL_TTL_HOURS=72
THEKEDAR_MAX_CODING_ITERATIONS=25

# --- M8 resilience / fail-closed prod ---
THEKEDAR_LLM_PRIMARY=gemini
THEKEDAR_LLM_FALLBACK=openai,anthropic
THEKEDAR_PROVIDER_RETRY_MAX=3
THEKEDAR_CIRCUIT_FAILURE_THRESHOLD=5
THEKEDAR_CIRCUIT_OPEN_SECONDS=60
THEKEDAR_OUTBOX_MAX_ATTEMPTS=8
THEKEDAR_ALLOW_DEFAULT_SEED=false
THEKEDAR_STRICT_INTEGRATIONS=false
THEKEDAR_MCP_FALLBACK_DIRECT_GITHUB=true
THEKEDAR_VALIDATE_ON_STARTUP=false
THEKEDAR_OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Outbound messaging ---
# SLACK_BOT_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

