# Thekedar — environment configuration
# Copy to .env or run: uv run thekedar init

# --- Core ---
THEKEDAR_ENVIRONMENT=local
THEKEDAR_DEMO_MODE=true
THEKEDAR_LOG_LEVEL=INFO

# --- Data stores ---
THEKEDAR_REDIS_URL=redis://localhost:6379/0
THEKEDAR_DATABASE_URL=postgresql://thekedar:thekedar@localhost:5432/thekedar

# --- Security (required in staging/prod) ---
# THEKEDAR_JWT_SECRET=
THEKEDAR_REQUIRE_WEBHOOK_SIGNATURE=false
THEKEDAR_WEBHOOK_RATE_LIMIT_RPS=100
THEKEDAR_MAX_REQUEST_BODY_BYTES=262144
THEKEDAR_DEFAULT_TENANT_ID=default

# --- Service URLs ---
THEKEDAR_DASHBOARD_URL=http://localhost:8081
THEKEDAR_WEBHOOK_INGRESS_URL=http://localhost:8080
THEKEDAR_WORKSPACE_CONFIG_PATH=config/workspace.yaml

# --- Pub/Sub (GCP / emulator) ---
# PUBSUB_EMULATOR_HOST=localhost:8085
# THEKEDAR_PUBSUB_PROJECT_ID=thekedar-local

# --- MCP gateway ---
THEKEDAR_BIFROST_URL=http://localhost:8090
# GITHUB_TOKEN=

# --- GitHub webhooks ---
# GITHUB_WEBHOOK_SECRET=

# --- Jira ---
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# --- GCP Workstations ---
# GCP_PROJECT_ID=
# GCP_REGION=us-central1

# --- Outbound messaging ---
# SLACK_BOT_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# --- Inbound webhooks (Slack / Meta) ---
# SLACK_SIGNING_SECRET=
# WHATSAPP_APP_SECRET=
# WHATSAPP_VERIFY_TOKEN=
